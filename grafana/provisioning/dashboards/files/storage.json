{
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "OBJECT STORAGE METRICS & PERFORMANCE (RED MODEL)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisPlacement": "left",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineInterpolation": "smooth",
            "lineWidth": 2
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "sum(rate(http_requests_total{app=\"object-storage\"}[1m])) by (method, status)", "legendFormat": "{{method}} ({{status}})", "refId": "A" }
      ],
      "title": "Storage Request Throughput (RED - Rate)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "sum(increase(http_requests_total{app=\"object-storage\", status=~\"[45]..\"}[1m])) by (status)", "legendFormat": "HTTP {{status}}", "refId": "A" }
      ],
      "title": "Storage Access Failures (RED - Errors)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisPlacement": "left",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineInterpolation": "smooth",
            "lineWidth": 2
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "sum(rate(http_request_duration_seconds_sum{app=\"object-storage\"}[1m])) by (method) / sum(rate(http_request_duration_seconds_count{app=\"object-storage\"}[1m])) by (method)", "legendFormat": "Method: {{method}}", "refId": "A" }
      ],
      "title": "Storage Average Access Latency (RED - Duration)",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["uastream", "object-storage"],
  "time": { "from": "now-15m", "to": "now" },
  "title": "05. UAStream Object Storage Dashboard",
  "uid": "uastream-object-storage",
  "version": 1
}
