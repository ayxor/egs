{
  "realm": "egs",
  "displayName": "UAStream EGS Platform",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 10,
  "accessTokenLifespan": 3600,
  "refreshTokenMaxReuse": 0,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionMaxLifespanEnabled": false,

  "clients": [
    {
      "clientId": "egs-platform",
      "name": "UAStream Composer Client",
      "description": "Confidential client used by the Composer service to authenticate users, refresh tokens, and create new accounts via the Admin REST API.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "change-me-in-production",
      "publicClient": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "alwaysDisplayInConsole": false,
      "frontchannelLogout": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://uastream.com/*",
        "http://localhost:8091/*", "http://localhost:8090/*",
        "http://127.0.0.1:8090/*",
        "http://localhost:8080/*",
        "http://127.0.0.1:8080/*"
      ],
      "webOrigins": [
        "http://localhost:8091", "http://localhost:8090",
        "http://127.0.0.1:8090",
        "http://localhost:8080",
        "http://127.0.0.1:8080"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://uastream.com/*##http://localhost:8091/*##http://localhost:8090/*##http://127.0.0.1:8090/*##http://localhost:8080/*##http://127.0.0.1:8080/*",
        "access.token.lifespan": "3600"
      },
      "protocolMappers": [
        {
          "name": "role-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "role",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "role",
            "jsonType.label": "String",
            "multivalued": "false",
            "aggregate.attrs": "false"
          }
        },
        {
          "name": "institution-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "institution",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "institution",
            "jsonType.label": "String",
            "multivalued": "false",
            "aggregate.attrs": "false"
          }
        }
      ]
    }
  ],

  "roles": {
    "realm": [],
    "client": {
      "egs-platform": []
    }
  },

  "users": [
    {
      "id": "ae3012a2-df6c-4f26-9203-f70e2f078d97",
      "username": "professor@ua.pt",
      "email": "professor@ua.pt",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Professor",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "professor",
          "temporary": false
        }
      ],
      "attributes": {
        "role": ["professor"],
        "institution": ["Universidade de Aveiro"]
      }
    },
    {
      "id": "10755f63-cd46-41b5-9f77-ef11b308cd40",
      "username": "student@ua.pt",
      "email": "student@ua.pt",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Student",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "student",
          "temporary": false
        }
      ],
      "attributes": {
        "role": ["student"],
        "institution": ["Universidade de Aveiro"]
      }
    },
    {
      "username": "service-account-egs-platform",
      "enabled": true,
      "serviceAccountClientId": "egs-platform",
      "clientRoles": {
        "realm-management": [
          "manage-users"
        ]
      }
    }
  ],

  "scopeMappings": [],

  "clientScopeMappings": {},

  "identityProviders": [],

  "identityProviderMappers": [],

  "components": {},

  "internationalizationEnabled": false,
  "supportedLocales": [],
  "defaultLocale": "en",

  "loginTheme": "uastream",
  "accountTheme": "keycloak",
  "adminTheme": "keycloak",
  "emailTheme": "keycloak",

  "eventsEnabled": false,
  "adminEventsEnabled": false,
  "adminEventsDetailsEnabled": false
}
